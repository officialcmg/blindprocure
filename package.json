{
  "name": "blindprocure",
  "private": true,
  "workspaces": [
    "contracts",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspace web",
    "compile:contracts": "npm run compile --workspace contracts",
    "dev": "npm run dev --workspace web",
    "test": "npm run test --workspace contracts",
    "verify:repo": "node scripts/verify-repo.mjs",
    "verify": "npm run verify:repo && npm run compile:contracts && npm run test && npm run build"
  }
}
